<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
	<Button
		id="vcrButton"
		icon="sap-icon://activity-2"
		type="{parts: ['followUp/ID', 'followUp/isSessionInterested'], formatter: 'formatter.buttonType'}"
		tooltip="{parts: ['followUp/ID', 'followUp/isSessionInterested'], formatter: 'formatter.tooltip'}"
		press="handler.onOpenVCRDialog"
		core:require="{
			handler: 'emlatracker/emlatracker/ext/controller/VCRDialogController',
			formatter: 'emlatracker/emlatracker/ext/formatter/VCRFormatter'
		}" />
</core:FragmentDefinition>
